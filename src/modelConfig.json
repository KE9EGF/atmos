            "WGNE": {
                "resolutions": null,
                "extension": ".grib2",
                "minHour": 3,
                "maxHour": 180,
                "stepping": [3],
                "analysisSupport": false,
                "fileName": "gfs.t{run}z.wgne.{fhr}"
                }
            }
        },
    "NAM": {
        "baseUrl": "https://nomads.ncep.noaa.gov/pub/data/nccf/com/nam/prod/"
